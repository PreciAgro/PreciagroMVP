# Temporal Logic Engine – example environment configuration

# Enable Pydantic .env loading in development
DEV=1

# Core services
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/temporal
REDIS_URL=redis://localhost:6379/0

# Optional integrations
SERVICE_JWT_PUBLIC_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Engine behaviour
ENABLE_WORKER=false
MAX_NOTIFS_PER_DAY=5
DIGEST_HOUR_LOCAL=19
LOG_LEVEL=INFO
ARQ_JOB_TIMEOUT=60
ARQ_MAX_RETRIES=3
ARQ_MAX_JOBS=10
ARQ_RETRY_JOBS=true
ARQ_MAX_TRIES=3
