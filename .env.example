ENVIRONMENT=local
DEBUG=true
DEBUG_MODE=false
HOST=0.0.0.0
PORT=8103
ENGINE_API_VERSION=v1
INTENT_SCHEMA_VERSION=intent-v1
RESPONSE_SCHEMA_VERSION=response-v1
ROUTER_VERSION=router-v1

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
MAX_REQUEST_SIZE_BYTES=10485760
ENABLE_HTTPS=false
SSL_CERT_FILE=certs/cert.pem
SSL_KEY_FILE=certs/key.pem

# Inbound auth (optional)
CONVERSATIONAL_API_KEY=your-conversational-api-key
ADMIN_API_KEY=admin-token
RATE_LIMIT_PER_MINUTE=120
TENANT_RATE_LIMIT_PER_MINUTE=600

# Session cache / retention
REDIS_URL=redis://localhost:6379/0
# Redis Sentinel (optional, leave blank for single-node)
REDIS_SENTINELS=
REDIS_SENTINEL_MASTER=mymaster
SESSION_TTL_SECONDS=3600
SESSION_HISTORY_TURNS=6
SESSION_RETENTION_HOURS=24
CONVERSATION_HISTORY_ENABLED=true

# AgroLLM endpoints (set when available)
AGROLLM_BACKEND=stub
AGROLLM_CLASSIFY_URL=https://your-agrollm/intent
AGROLLM_GENERATE_URL=https://your-agrollm/generate
AGROLLM_API_KEY=your-agrollm-api-key
CONVERSATION_SYSTEM_PROMPT=

# Downstream engines
GEO_CONTEXT_URL=http://localhost:8102/geo-context/fco
TEMPORAL_LOGIC_URL=http://localhost:8100/temporal/intents
CROP_INTELLIGENCE_URL=http://localhost:8104/crop-intel
INVENTORY_URL=http://localhost:8105/inventory
IMAGE_ANALYSIS_URL=http://localhost:8106/image-analysis
INTERNAL_API_KEY=shared-internal-key

# RAG (defaults work in-memory)
FLAG_ENABLE_RAG=true
RAG_BACKEND=qdrant
RAG_INDEX_PATH=preciagro/packages/engines/conversational_nlp/data/rag_seed.json
QDRANT_HOST=:memory:
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=conversational_rag
RAG_EMBEDDER_MODEL=sentence-transformers/all-mpnet-base-v2

# Feature flags
FLAG_ENABLE_IMAGE_ENGINE=true
FLAG_ENABLE_TEMPORAL_ENGINE=true
FLAG_ENABLE_GEO_ENGINE=true
FLAG_FORCE_RULE_BASED_MODE=false

# Connector resilience
ENGINE_RETRY_ATTEMPTS=2
ENGINE_RETRY_BACKOFF_SECONDS=0.5

# Database pooling
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Logging / persistence / privacy
CONVERSATION_LOG_PATH=reports/conversation_turns.jsonl
LOG_RETENTION_DAYS=30
ANONYMIZE_LOGS=false

# Input / attachments
MAX_MESSAGE_LENGTH=12000
MAX_ATTACHMENTS=5
MAX_ATTACHMENT_BYTES=5242880
ALLOWED_ATTACHMENT_MIME_TYPES=image/jpeg,image/png

# OTLP tracing (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=conversational-nlp

# Sentry error tracking (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
