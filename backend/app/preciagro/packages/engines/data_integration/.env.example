# Data Integration Engine – environment template

# Ensure settings.Config loads this file in development
DEV=1

# External data source credentials
OPENWEATHER_API_KEY=

# Storage & messaging
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/preciagro
REDIS_URL=redis://localhost:6379/0

# Throttling
INGEST_RATE_LIMIT_QPS=5

# Optional: adjust logging verbosity
LOG_LEVEL=INFO
