# GeoContext Engine – example environment configuration

# Toggle development helpers (stub JWT + seeded data fallbacks)
DEV_MODE=true

# Database configuration (PostgreSQL with PostGIS extension)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/geo_context
ENABLE_POSTGIS=false

# Cache configuration (optional)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# HTTP server settings
ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# External integrations (leave blank to use built-in fallbacks)
WEATHER_API_URL=
WEATHER_API_KEY=
SOIL_API_URL=
SOIL_API_KEY=

# JWT public key for production verification (PEM). Leave empty in DEV_MODE.
JWT_PUBKEY=
