# PreciAgro MVP Environment Configuration
# 
# SECURITY NOTICE:
# - This file documents required environment variables
# - DO NOT commit secrets to version control
# - All sensitive values must be set via environment variables
# - The .env file is gitignored and should never be committed
# 
# For development, copy this file to .env and fill in actual values:
#   cp .env.example .env
#
# REQUIRED VARIABLES (application will fail to start without these)

# Authentication & Security
JWT_PUBKEY=<your-rsa-public-key-in-pem-format>
# Example: A valid RS256 public key in PEM format starting with -----BEGIN PUBLIC KEY-----

# Database Configuration
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/preciagro
# Format: postgresql+asyncpg://[user]:[password]@[host]:[port]/[database]
# For production, use a secure database URL with strong credentials

# Cache & Message Queue
REDIS_URL=redis://localhost:6379/0
# Format: redis://[username:password@]hostname[:port]/[database]

# External API Keys
OPENWEATHER_API_KEY=<your-openweather-api-key>
# Get from: https://openweathermap.org/api

# OPTIONAL VARIABLES (have sensible defaults)

# Environment & Logging
ENVIRONMENT=development
# Allowed values: development, staging, production
LOG_LEVEL=INFO
# Allowed values: DEBUG, INFO, WARNING, ERROR, CRITICAL

# Data Integration
INGEST_RATE_LIMIT_QPS=5
# Requests per second for data ingestion

# CORS Configuration (if needed)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
# Comma-separated list of allowed origins in non-development environments

# Temporal Logic Engine
TEMPORAL_JWT_SECRET=<your-jwt-secret-for-temporal-logic>
# Required for temporal logic engine JWT operations

# PRODUCTION DEPLOYMENT CHECKLIST:
# 
# Before deploying to production:
# 1. ✓ Set JWT_PUBKEY to a valid production RSA public key
# 2. ✓ Set DATABASE_URL to production database with strong credentials
# 3. ✓ Set REDIS_URL to production Redis instance with authentication
# 4. ✓ Set OPENWEATHER_API_KEY to production API key
# 5. ✓ Set ENVIRONMENT=production
# 6. ✓ Set CORS_ORIGINS to actual production domain(s)
# 7. ✓ Rotate all secrets regularly
# 8. ✓ Use a secrets manager (e.g., AWS Secrets Manager, HashiCorp Vault)
# 9. ✓ Never log or expose JWT_PUBKEY, API keys, or database passwords
# 10. ✓ Verify all secrets are loaded from environment variables only

